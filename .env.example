# Firebase – from your project’s Firebase Console → Project settings → General.
# Create a project at https://console.firebase.google.com then enable Auth (Email/Password), Firestore, Storage.

VITE_FIREBASE_API_KEY="your-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="123456789"
VITE_FIREBASE_APP_ID="1:123456789:web:abc123"

# Optional: use Firebase emulators in development
# VITE_FIREBASE_USE_EMULATORS=true

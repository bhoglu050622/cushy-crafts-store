# Supabase – from your project’s Dashboard → Settings → API.
# For a new project, see NEW_SUPABASE_SETUP.md and run: node scripts/setup-new-supabase.js

# Direct Supabase URL (may be blocked on Jio India – use proxy URL below in that case):
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"

# Proxy URL (after deploying supabase-proxy Worker – use this for Jio/blocked networks):
# VITE_SUPABASE_URL="https://supabase-proxy.<your-subdomain>.workers.dev"

VITE_SUPABASE_PROJECT_ID="YOUR_PROJECT_ID"
VITE_SUPABASE_PUBLISHABLE_KEY="<your-anon-public-key>"
